# Copy this file to .env and fill in your values
# Never commit .env to version control

# Required: Google Gemini API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: anonymous usage analytics (PostHog)
# When set, the frontend records anonymous page visits + a "query_submitted"
# event (metadata only, never the question text). Approximate location
# (country/region/city) is derived server-side by PostHog from the IP.
# Leave POSTHOG_KEY empty to fully disable analytics.
# Get a free project key at https://posthog.com (Project settings → API keys).
# POSTHOG_KEY=phc_your_project_key_here
# POSTHOG_HOST=https://us.i.posthog.com   # use https://eu.i.posthog.com for the EU cloud

# Optional: LangSmith tracing
# Set TRACING_V2=true to capture every LangChain / LangGraph step in LangSmith.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=regiq
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
